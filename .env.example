# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Wallet private key (NEVER share this or commit it)
WALLET_PRIVATE_KEY=your_private_key_here

# Default chain (ethereum | bsc | polygon | arbitrum | base)
DEFAULT_CHAIN=ethereum

# Slippage tolerance in percent (e.g. 5 = 5%)
SLIPPAGE_PERCENT=5

# Price check interval in seconds
PRICE_CHECK_INTERVAL=30

# Allowed Telegram user IDs (comma-separated). Leave empty to allow all.
ALLOWED_USER_IDS=

# Optional: Custom RPC URLs (overrides defaults)
ETH_RPC_URL=
BSC_RPC_URL=
POLYGON_RPC_URL=
ARBITRUM_RPC_URL=
BASE_RPC_URL=
